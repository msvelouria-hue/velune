# .env.example - Copy this to .env and fill in your values.
# Only use EXPO_PUBLIC_* for values that are safe to ship in the mobile app.
# Expo inlines EXPO_PUBLIC_* values into the client bundle at build time.

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_PROJECT_ID=style-genie-f65ef
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=style-genie-f65ef.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Sign In (Required for Google authentication)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id

# Server-side secrets
# Configure these in Firebase Functions instead of shipping them in the app bundle.
# Do not create EXPO_PUBLIC_OPENAI_API_KEY, EXPO_PUBLIC_VUXO_API_KEY,
# EXPO_PUBLIC_REMOVE_BG_API_KEY, or EXPO_PUBLIC_PHOTOROOM_API_KEY.
# firebase functions:secrets:set VUXO_API_KEY
# firebase functions:secrets:set OPENAI_API_KEY

# Weather
EXPO_PUBLIC_WEATHER_API_KEY=your_openweather_api_key

# App Configuration
EXPO_PUBLIC_IOS_BUNDLE_ID=co.velouria.vestiary
